# CITYMO ERP — Supabase project npddbwsskaojcawaxygh
VITE_SUPABASE_URL=https://npddbwsskaojcawaxygh.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Optional — Express API (legacy commercial + OCR Mindee backend)
# VITE_API_URL=http://localhost:3000/api
# Prod Vercel (sans VITE_API_URL) : OCR via /api/ocr/moroccan-cin (serverless).

# OCR Mindee — Vercel → Settings → Environment Variables (Production + Preview) :
# MINDEE_API_KEY=md_xxx ou re_xxx
# MINDEE_MODEL_ID=uuid (obligatoire si clé md_*)
# OCR_PROVIDER=mindee
# Ne pas définir VITE_API_URL sur Vercel (l'app appelle /api/ocr/moroccan-cin sur le même domaine).
# Pour sauvegardes + mot de passe admin (proxy Vercel → Railway) :
# RAILWAY_API_URL=https://votre-app.railway.app
# Debug OCR client (console détaillée) : VITE_OCR_DEBUG=true
# ou dans la console navigateur : localStorage.setItem('citymo_ocr_debug','1')

# Backend OCR local (server/.env — jamais dans le frontend) :
# MINDEE_API_KEY=re_xxx
# MINDEE_MODEL_ID=optional
# OCR_PROVIDER=mindee   # ou "mock" pour demo

# ─── Edge Function notify-leave-request (secrets Supabase uniquement) ───
# Guide complet : supabase/functions/notify-leave-request/README.md
#
# supabase secrets set RESEND_API_KEY=re_xxx LEAVE_NOTIFY_TO=selim.moumni@citymo.ma
# supabase functions deploy notify-leave-request
#
# RESEND_API_KEY     — clé API Resend (obligatoire pour envoi réel)
# LEAVE_NOTIFY_TO    — selim.moumni@citymo.ma
# LEAVE_NOTIFY_FROM  — ex. CITYMO Congés <conges@citymo.ma> ou onboarding@resend.dev (test)
# LEAVE_APP_URL      — URL app pour lien CTA dans l'email (optionnel)
