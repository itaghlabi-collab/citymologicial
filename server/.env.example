# CITYMO ERP — Backend Express (port 3000)
PORT=3000

# ── Railway (obligatoire pour sauvegardes + auth Super Admin) ───────────────
# SUPABASE_URL est optionnel si le projet CITYMO par défaut est utilisé.
# Copier depuis Vercel → Settings → Environment Variables :
SUPABASE_URL=https://npddbwsskaojcawaxygh.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Origines CORS supplémentaires (séparées par des virgules) :
# ALLOWED_ORIGINS=https://preview.example.com

# ── Supabase (sauvegardes ERP — service_role jamais côté client) ─────────────
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Provider : supabase_storage | local
BACKUP_STORAGE_PROVIDER=supabase_storage
BACKUP_LOCAL_DIR=./data/backups

# Fichiers Storage : manifest (défaut, rapide) | full (copie binaire lente)
BACKUP_FILES_MODE=manifest
# BACKUP_FILES_MODE=full
# BACKUP_FILE_COPY_CONCURRENCY=4
# BACKUP_FILE_COPY_TIMEOUT_MS=120000
# BACKUP_MAX_FILE_BYTES=104857600
# BACKUP_DRIVE_UPLOAD_TIMEOUT_MS=300000
# BACKUP_PROGRESS_STALE_MS=120000
# BACKUP_HEARTBEAT_STALE_MS=180000
# BACKUP_STUCK_AFTER_MS=600000

# ── Google Drive (2e copie) — projet citymo-erp-sauvegardes ───────────────────
# Compte de service : citymo-backup-service@citymo-erp-sauvegardes.iam.gserviceaccount.com
# Dossier Drive partagé (Éditeur) avec ce compte de service
BACKUP_GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_FOLDER_ID=1EmDiULTRrP2BuLlaLhh1A1CFXkGgN59t
# Fichier JSON téléchargé depuis GCP → Identifiants → Compte de service → Clés
# Coller le JSON COMPLET sur une seule ligne (pas seulement l'ID de clé)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"citymo-erp-sauvegardes",...}

# ── OCR CIN marocaine — Mindee ────────────────────────────────────────────────
# https://platform.mindee.com
MINDEE_API_KEY=md_votre_cle_ici

# mindee = production | mock = données test JIHANE ELOUADOUD
OCR_PROVIDER=mindee

# ── Clé md_* (API v2) : Model ID obligatoire ──
# Ce n'est PAS l'Organization ID (Settings → Organization).
# Le catalogue "International ID" n'a pas de Model ID global :
# chaque compte reçoit un UUID unique à la création du modèle.
#
# Option A — Model ID direct (Settings ⚙ du modèle → "Model ID") :
# MINDEE_MODEL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Option B — Coller l'URL Live Test depuis le navigateur :
# MINDEE_MODEL_URL=https://app.mindee.com/models/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/live-test
#
# Où trouver l'UUID :
# 1. Dashboard Mindee → Models
# 2. Cliquer sur votre modèle "International ID"
# 3. L'UUID est dans l'URL (/models/{uuid}/...) OU dans Settings → Model ID

MINDEE_MODEL_ID=
# MINDEE_MODEL_URL=
