{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/admin/users/:id/password", "destination": "/api/admin-user-password?id=:id" },
    { "source": "/api/admin/users/:id/email", "destination": "/api/admin-user-email?id=:id" },
    { "source": "/api/backups/status/config", "destination": "/api/erp-snapshot-router?route=status/config" },
    { "source": "/api/backups/status/drive", "destination": "/api/erp-snapshot-router?route=status/drive" },
    { "source": "/api/backups/:id/download", "destination": "/api/erp-snapshot-router?id=:id&action=download" },
    { "source": "/api/backups/:id/drive", "destination": "/api/erp-snapshot-router?id=:id&action=drive" },
    { "source": "/api/backups/:id/restore", "destination": "/api/erp-snapshot-router?id=:id&action=restore" },
    { "source": "/api/backups/:id", "destination": "/api/erp-snapshot-router?id=:id" },
    { "source": "/api/backups", "destination": "/api/erp-snapshot-router" },
    { "source": "/((?!api/|assets/|sounds/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/sounds/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "functions": {
    "api/ocr/moroccan-cin.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/erp-snapshot-router.js": {
      "maxDuration": 60
    },
    "api/admin/users/[...path].js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/admin-user-password.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/admin-user-email.js": {
      "maxDuration": 60,
      "memory": 512
    }
  }
}
